{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    { "path": "/api/cron/run?job=daily-briefing",    "schedule": "0 7 * * *" },
    { "path": "/api/cron/run?job=process-queue",     "schedule": "0 8 * * *" },
    { "path": "/api/cron/run?job=check-alerts",      "schedule": "0 9 * * *" },
    { "path": "/api/cron/run?job=sync-all-accounts", "schedule": "0 10 * * *" },
    { "path": "/api/cron/run?job=release-expired",   "schedule": "0 11 * * *" },
    { "path": "/api/cron/run?job=weekly-report",     "schedule": "0 20 * * 0" },
    { "path": "/api/cron/run?job=run-automations",   "schedule": "0 6 * * *" },
    { "path": "/api/cron/run?job=check-oracle-subscriptions", "schedule": "0 12 * * *" }
  ],
  "rewrites": [
    { "source": "/api/whatsapp/send",   "destination": "/api/whatsapp/send.js" },
    { "source": "/api/telegram/send",   "destination": "/api/telegram/send.js" },
    { "source": "/((?!api/).*)",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
